# Copy this file to apps/web/.env.local for local Next.js development.

# Canonical origin used for authentication callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase public client configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional fallback for older Supabase projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-owned release switch. Keep false in Production until the Staging V2
# gate passes; local development may set true to exercise the full revision flow.
LIVE_TRAINING_V2=true

# Server-only Supabase key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# AI Coach runtime. Use mock for deterministic local development or live for OpenAI.
STG_AI_MODE=mock
# Keep sync for local/preview work. Enable background in an isolated Staging
# environment only after applying migrations and registering the webhook.
STG_AI_EXECUTION_MODE=sync
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_WEBHOOK_SECRET=

# Vercel Cron automatically sends this value as a Bearer token.
CRON_SECRET=

# Local-only fallbacks. Both flags are ignored when NODE_ENV=production.
STG_ENABLE_DEV_AUTH=false
STG_ENABLE_DEV_ADMIN=false
